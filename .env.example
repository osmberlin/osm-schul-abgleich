# Copy to `.env` and fill in. Vite only exposes variables prefixed with `VITE_`.

# OAuth 2 — https://www.openstreetmap.org/oauth2/applications/new
#
# Register these redirect URIs on the OSM app (exact match, one line each):
#   http://127.0.0.1:5174/osm-oauth-land.html          (local dev)
#   https://schulabgleich.osm-verkehrswende.org/osm-oauth-land.html   (production)
# 
# IMPORTANT — "Confidential application?" must be UNCHECKED (public client).
# SPAs / browser apps cannot keep a client secret; osm-api uses PKCE only.
# If you register as confidential, token exchange returns 401 Unauthorized.
# See: https://wiki.openstreetmap.org/wiki/OAuth#Registering_your_application_as_OAuth_2.0_consumer
#
# Enable scopes on the OSM app (must match what the app requests):
#   read_prefs — user display name via /api/0.6/user/details.json (getUser('me'))
#   write_api — upload changesets
#
# Local: open the app at http://127.0.0.1:5174 (not http://localhost:5174) so
# window.location.origin matches the first URI. Production: redirect URL is
# origin + Vite base path + osm-oauth-land.html (must match the production URI above).
#
# GitHub Actions: add the same value as repository secret VITE_OSM_OAUTH_CLIENT_ID (pages.yml build step).
VITE_OSM_OAUTH_CLIENT_ID=
