# Pipeline internal cache (Overpass output for match step).
.pipeline/

# Downloaded / pipeline-generated artifacts.
jedeschule-latest.csv

# National index written by the pipeline (`pipelineVersion`, per-Land entries, …).
summary.json
# Legacy national aggregates (no longer produced; ignore if present locally).
schools_official_de.geojson
schools_osm_de.geojson
schools_matches_de.json

# Local-only national metadata snapshots.
schools_official_de.meta.dev.json
schools_osm_de.meta.dev.json

# Run history from refresh/deploy workflows.
status/*
!status/
!status/runs.jsonl
status/runs.dev.json
status/runs.dev.jsonl

